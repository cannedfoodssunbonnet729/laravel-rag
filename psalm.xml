<?xml version="1.0"?>
<psalm
    errorLevel="1"
    resolveFromConfigFile="true"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xmlns="https://getpsalm.org/schema/config"
    xsi:schemaLocation="https://getpsalm.org/schema/config vendor/vimeo/psalm/config.xsd"
    findUnusedCode="true"
    findUnusedVariables="true"
    reportMixedIssues="true"
>
    <projectFiles>
        <directory name="src" />
        <ignoreFiles>
            <directory name="vendor" />
        </ignoreFiles>
    </projectFiles>

    <taintAnalysis>
        <taintSource>
            <!-- MCP tool arguments are user-controlled -->
            <className name="Moneo\LaravelRag\Mcp\RagMcpServer" method="handleToolCall" />
        </taintSource>
    </taintAnalysis>
</psalm>
